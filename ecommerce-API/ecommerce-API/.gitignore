# ===============================
# Node.js API .gitignore
# ===============================

# dependencies
node_modules/

# lock files (ignore if you don't want them in repo)
package-lock.json
yarn.lock
pnpm-lock.yaml

# environment variables
.env
.env.*
!.env.example

# logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# runtime data
pids
*.pid
*.seed
*.pid.lock

# coverage / testing
coverage/
.nyc_output/

# build output
dist/
build/

# cache
.cache/
.eslintcache

# OS files
.DS_Store
Thumbs.db

# IDE / Editor
.vscode/
.idea/
*.swp

# temp files
tmp/
temp/
